  shorttitle = {Statistical Analysis Plan for the {{OPTIMUM}} Study},
  author = {Totterdell, James A. and Chacon, Gladymar Perez and Estcourt, Marie J. and Jones, Mark and Richmond, Peter and Snelling, Thomas L. and Marsh, Julie A.},
  date = {2022-02-07},
